{
  "name": "@universalmanifest/typescript",
  "version": "0.1.0",
  "description": "Standalone TypeScript reference implementation for Universal Manifest",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test tests/unit/*.test.mjs",
    "conformance": "npm run build && node tests/conformance/run-conformance.mjs"
  },
  "keywords": [
    "universal-manifest",
    "reference-implementation",
    "typescript",
    "json-ld",
    "ed25519"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grigb/um-typescript.git"
  },
  "homepage": "https://github.com/grigb/um-typescript",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  }
}
